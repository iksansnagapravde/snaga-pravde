def extract_prices(text):
    prices = []

    matches = re.findall(r"\d{1,3}(?:\.\d{3})*,\d{2}", text)

    for m in matches:
        try:
            num = float(m.replace(".", "").replace(",", "."))

            # 🔥 КРИТИЧНИ ФИЛТЕРИ
            if num < 100000:     # испод 100k није тендер
                continue

            if num > 10000000000:  # OCR грешка
                continue

            prices.append(num)

        except:
            pass

    prices = list(set(prices))
    prices.sort()

    print("PRICES:", prices)

    return prices
