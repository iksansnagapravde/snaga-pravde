<style>
:root{
  --blue:#0a3f78;
  --blue-dark:#08325e;
  --blue-soft:#eef4fb;
  --orange:#ff5a1f;
  --orange-dark:#e44e16;
  --text:#111;
  --soft:#575757;
  --line:rgba(0,0,0,0.12);
  --green:#25D366;
  --gold:#d3a451;
  --danger:#c0392b;
  --success:#2e8b57;
}

*{box-sizing:border-box;margin:0;padding:0}
a{text-decoration:none;color:inherit}

html,body{
  max-width:100%;
  overflow-x:hidden;
}

body{
  font-family:"Playfair Display",serif;
  color:var(--text);
  padding-bottom:140px;
  overflow-x:hidden;
}

/* POZADINA */
body::before{
  content:"";
  position:fixed;
  inset:0;
  z-index:-1;
  background:url('lady-justice-hero.webp') center top / cover no-repeat;
  animation:goddessReveal 1.35s ease-out both;
  transform-origin:bottom right;
}

@keyframes goddessReveal{
  0%{
    transform:translate(120px,140px) scale(1.12);
    opacity:0.82;
  }
  100%{
    transform:translate(0,0) scale(1);
    opacity:1;
  }
}

/* HEADER */
header{
  position:sticky;
  top:0;
  background:#fff;
  border-bottom:1px solid var(--line);
  z-index:1000;
}

.head{
  max-width:1150px;
  margin:auto;
  padding:12px 0;
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.brand{
  display:flex;
  align-items:center;
  gap:12px;
  padding-left:12px;
}

.logo-box{
  width:72px;
  height:72px;
  background:var(--blue);
  display:flex;
  align-items:center;
  justify-content:center;
}

.logo-box img{
  width:66px;
}

.brand-text .top{
  font-size:0.6rem;
  color:#777;
}

.brand-text .main{
  font-size:0.76rem;
  font-weight:600;
  white-space:nowrap;
}

.nav-right{
  display:flex;
  align-items:center;
  gap:12px;
  padding-right:12px;
}

.donate-btn{
  background:var(--orange);
  color:#fff;
  padding:10px 20px;
  font-size:0.75rem;
  font-weight:700;
}

.menu{position:relative}

.menu-btn{
  width:26px;
  height:18px;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
  cursor:pointer;
}

.menu-btn span{
  height:2px;
  background:#000;
}

.dropdown{
  position:absolute;
  top:calc(100% + 10px);
  right:0;
  background:#fff;
  border:1px solid var(--line);
  display:none;
  min-width:290px;
  z-index:1200;
}

.menu.open .dropdown{display:block}

.dropdown a{
  display:block;
  padding:10px 14px;
  font-size:0.85rem;
  border-bottom:1px solid var(--line);
}

/* HERO */
.hero-space{
  height:240px;
}

.top-buttons{
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:14px;
  margin-top:-80px;
}

.btn-lite{
  background:#fff;
  border:1px solid rgba(10,63,120,0.25);
  padding:12px 24px;
  font-size:0.85rem;
  color:var(--blue);
  font-weight:600;
}

.btn-main{
  background:var(--blue);
  color:#fff;
  padding:16px 30px;
  font-size:0.95rem;
  font-weight:700;
}

/* LAYOUT */
.container{
  max-width:1150px;
  margin:auto;
  padding:20px;
}

.section-card{
  margin-top:24px;
  padding:24px;
  background:#fff;
  border:1px solid var(--line);
  box-shadow:0 10px 30px rgba(0,0,0,0.08);
}

.section-card.blue{
  background:var(--blue);
  color:#fff;
}

.section-card.blue p,
.section-card.blue li,
.section-card.blue td,
.section-card.blue th,
.section-card.blue .note-box,
.section-card.blue .info-box,
.section-card.blue .policy-box,
.section-card.blue .measure-item{
  color:#eef3fb;
}

.section-card h1{
  font-size:22px;
  font-weight:600;
  margin-bottom:12px;
}

.section-card h2{
  font-size:18px;
  font-weight:600;
  margin-bottom:14px;
}

.section-card h3{
  font-size:15px;
  font-weight:600;
  margin-bottom:8px;
}

.section-card p,
.section-card li,
.section-card td,
.section-card th{
  font-size:0.75rem;
  line-height:1.75;
  letter-spacing:0.1px;
  color:var(--soft);
}

.section-card strong,
.section-card b{
  color:inherit;
}

.hero-intro{
  text-align:center;
}

.hero-intro .sub{
  max-width:930px;
  margin:auto;
}

.main-grid{
  display:grid;
  gap:24px;
  margin-top:24px;
}

@media(min-width:950px){
  .main-grid{
    grid-template-columns:1.15fr 0.85fr;
  }
}

.full-span{
  grid-column:1 / -1;
}

/* BOXES */
.note-box{
  margin-top:18px;
  padding:18px;
  background:#fff6f5;
  border-left:4px solid var(--danger);
}

.info-box{
  margin-top:18px;
  padding:18px;
  background:#f5f8fc;
  border-left:4px solid var(--blue);
}

.policy-box{
  margin-top:18px;
  padding:18px;
  background:#f7fafc;
  border-left:4px solid var(--success);
}

.section-card.blue .note-box,
.section-card.blue .info-box,
.section-card.blue .policy-box{
  background:rgba(255,255,255,0.08);
  border-left-color:#fff;
}

/* TABLES */
.table-wrap{
  width:100%;
  max-width:100%;
  overflow-x:auto;
  margin-top:20px;
  border:1px solid var(--line);
  -webkit-overflow-scrolling:touch;
}

.table-wrap table{
  width:100%;
  border-collapse:collapse;
  background:#fff;
  table-layout:fixed;
}

.table-wrap th,
.table-wrap td{
  padding:12px 10px;
  text-align:center;
  border-bottom:1px solid var(--line);
  word-break:break-word;
  overflow-wrap:break-word;
  hyphens:auto;
}

.table-wrap th{
  background:#f3f7fc;
  font-size:12px;
}

.table-wrap td{
  font-size:0.74rem;
  color:var(--soft);
}

.table-wrap tr:last-child td{
  border-bottom:none;
}

/* CHART */
.chart-wrap{
  margin-top:22px;
  background:#fbfcfe;
  border:1px solid var(--line);
  padding:16px;
}

.section-card.blue .chart-wrap{
  background:rgba(255,255,255,0.06);
  border-color:rgba(255,255,255,0.12);
}

canvas{
  width:100% !important;
  height:380px !important;
}

.chart-note{
  margin-top:12px;
  font-size:0.74rem;
  line-height:1.7;
  color:var(--soft);
}

.section-card.blue .chart-note{
  color:#eef3fb;
}

/* POLICY CARDS */
.highlight-grid{
  display:grid;
  gap:20px;
  margin-top:24px;
}

@media(min-width:900px){
  .highlight-grid{
    grid-template-columns:1fr 1fr;
  }
}

.highlight-card{
  background:linear-gradient(180deg,#ffffff,#eef4fb);
  padding:24px;
  border:1px solid rgba(10,63,120,0.16);
  box-shadow:0 10px 24px rgba(0,0,0,0.05);
}

.highlight-card h3{
  font-size:15px;
  margin-bottom:8px;
}

.highlight-card p{
  font-size:0.75rem;
  line-height:1.75;
  color:var(--soft);
}

/* MEASURES */
.measure-list{
  display:grid;
  gap:12px;
  margin-top:12px;
}

.measure-item{
  padding:14px 16px;
  background:#f8fafc;
  border:1px solid var(--line);
  line-height:1.7;
  font-size:0.74rem;
  color:var(--soft);
}

.measure-item b{
  display:block;
  color:var(--text);
  margin-bottom:4px;
}

.section-card.blue .measure-item{
  background:rgba(255,255,255,0.08);
  border-color:rgba(255,255,255,0.14);
}

.section-card.blue .measure-item b{
  color:#fff;
}

/* SOCIAL */
.social-bar{
  position:fixed;
  right:-80px;
  bottom:120px;
  display:flex;
  flex-direction:column;
  gap:12px;
  z-index:9999;
  transition:0.6s;
  opacity:0;
}

.social-bar.show{
  right:12px;
  opacity:1;
}

.social-bar a{
  width:44px;
  height:44px;
  display:flex;
  align-items:center;
  justify-content:center;
  background:#fff;
  border:1px solid var(--line);
}

.social-bar img{
  width:20px;
}

/* WHATSAPP */
.wa-btn{
  position:fixed;
  right:-220px;
  bottom:50px;
  display:flex;
  align-items:center;
  gap:10px;
  padding:12px 14px;
  background:#25D366;
  color:#fff;
  font-size:0.8rem;
  font-weight:600;
  border-radius:40px;
  box-shadow:0 10px 25px rgba(37,211,102,0.4);
  transition:0.6s;
  z-index:10000;
}

.wa-btn.show{
  right:12px;
}

.wa-btn img{
  width:22px;
  filter:brightness(0) invert(1);
}

/* MOBILE */
@media(max-width:768px){
  .hero-space{height:180px;}
  .top-buttons{margin-top:-50px;padding:0 10px;}
  .container{padding:15px;}
  .section-card{padding:18px;}
  canvas{height:280px !important;}
  .brand-text .main{white-space:normal;}
}
</style>
